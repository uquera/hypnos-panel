// Hypnos Panel — Schema de base de datos
// SQLite + Prisma v6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── USUARIOS DEL PANEL ────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  role         String   @default("COBRADOR") // ADMIN | COBRADOR
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  pagos        Pago[]

  @@map("users")
}

// ─── CLIENTES SaaS ────────────────────────────────────────────────────────────

model Cliente {
  id               String    @id @default(cuid())
  nombre           String                         // "Centro Bambú"
  dominio          String                         // "centrobambu.cl"
  apiUrl           String                         // "https://centrobambu.cl/api/gobernanza/licencia"
  masterKey        String                         // GOBERNANZA_MASTER_KEY de esa instancia
  plan             String    @default("BASICO")   // BASICO | PRO | ENTERPRISE
  fechaVencimiento DateTime
  suspendida       Boolean   @default(false)
  notasAdmin       String?
  emailContacto    String?                        // email del contacto para alertas de vencimiento
  activo           Boolean   @default(true)
  ultimoCheck      DateTime?                      // última verificación de salud
  ultimoCheckOk    Boolean?                       // resultado del último health check
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  pagos            Pago[]

  @@map("clientes")
}

// ─── PAGOS ────────────────────────────────────────────────────────────────────

model Pago {
  id              String   @id @default(cuid())
  clienteId       String
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  monto           Float
  moneda          String   @default("USD")      // USD | CLP | EUR
  periodoInicio   DateTime
  periodoFin      DateTime
  fechaPago       DateTime @default(now())
  comprobante     String?                        // nombre del archivo en uploads/comprobantes/
  notas           String?
  registradoPorId String
  registradoPor   User     @relation(fields: [registradoPorId], references: [id])
  createdAt       DateTime @default(now())

  @@map("pagos")
}

// ─── LOG DE ACTIVIDAD ─────────────────────────────────────────────────────────
// Tabla de auditoría. Denormalizada a propósito: si se archiva un cliente o
// se elimina un usuario, el log histórico permanece intacto.

model ActividadLog {
  id            String   @id @default(cuid())
  usuarioId     String
  usuarioNombre String
  clienteId     String?
  clienteNombre String?
  accion        String   // LICENCIA_SYNC | PAGO_REGISTRADO | RENOVACION | CLIENTE_CREADO | CLIENTE_ARCHIVADO
  detalle       String?
  createdAt     DateTime @default(now())

  @@map("actividad_log")
}

// ─── NextAuth — sesiones JWT (no requiere tablas adicionales) ─────────────────
